# Dong Build Configuration - HarmonyOS (鸿蒙)
# Copy this file to build.env and adjust paths for your system
#
# HarmonyOS cross-compilation requires:
# 1. HarmonyOS DevEco Studio installed
# 2. Target architecture specified in zig build command
#
# Example build commands:
#   zig build -Dtarget=aarch64-linux-ohos            # HarmonyOS ARM64
#
# The build will automatically enter "libs-only" mode for mobile targets,
# building only static libraries for integration into native HarmonyOS apps.

# HarmonyOS SDK path (optional)
# OHOS_SDK_PATH=/path/to/ohos-sdk

# =============================================================================
# Integration Guide for HarmonyOS Projects
# =============================================================================
#
# After building with zig build -Dtarget=aarch64-linux-ohos:
#
# 1. Static libraries will be in: zig-out/lib/
#    - libquickjs.a
#    - liblexbor_static.a
#    - libyogacore.a
#    - libfreetype.a
#    - libharfbuzz.a
#    - libmsdfgen.a
#
# 2. Copy libraries to your HarmonyOS project:
#    entry/libs/arm64-v8a/
#
# 3. In your CMakeLists.txt, link against these libraries:
#    target_link_libraries(entry PUBLIC
#        ${CMAKE_CURRENT_SOURCE_DIR}/../libs/${OHOS_ARCH}/libquickjs.a
#        ${CMAKE_CURRENT_SOURCE_DIR}/../libs/${OHOS_ARCH}/liblexbor_static.a
#        # ... etc
#    )
#
# 4. Header files are in: zig-out/include/
#    Add to include_directories in CMakeLists.txt
#
# =============================================================================
# NAPI Integration
# =============================================================================
#
# For JavaScript integration via NAPI:
#
# 1. Create a NAPI module wrapping the dong C API
# 2. Register the module in module.json5
# 3. Call from ArkTS/JavaScript
#
# Example NAPI registration:
#   static napi_module dongModule = {
#       .nm_version = 1,
#       .nm_flags = 0,
#       .nm_filename = nullptr,
#       .nm_register_func = Init,
#       .nm_modname = "dong",
#       .nm_priv = nullptr,
#       .reserved = { 0 },
#   };
#
# =============================================================================
