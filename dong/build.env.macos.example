# Dong Build Configuration - macOS Example
# Copy this file to build.env and modify paths for your system

# =============================================================================
# VulkanSDK Configuration
# =============================================================================
# Download from: https://vulkan.lunarg.com/sdk/home#mac
# Example: /Users/username/VulkanSDK/1.4.328.1/macOS
VULKAN_SDK_PATH=/Users/username/VulkanSDK/1.4.328.1/macOS

# =============================================================================
# DXC (DirectX Shader Compiler) Configuration
# =============================================================================
# Download from: https://github.com/nicebyte/dxc-builds/releases
# Example: third_party/DXC-1.8.2505.1/lib/macosx
DXC_LIB_PATH=third_party/DXC-1.8.2505.1/lib/macosx

# DXC include path (optional)
DXC_INCLUDE_PATH=third_party/DXC-1.8.2505.1/include
