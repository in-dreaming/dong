# Dong Build Configuration - Windows Example
# Copy this file to build.env and modify paths for your system

# =============================================================================
# VulkanSDK Configuration
# =============================================================================
# Download from: https://vulkan.lunarg.com/sdk/home#windows
# Example: C:/VulkanSDK/1.3.290.0
VULKAN_SDK_PATH=C:/VulkanSDK/1.4.328.1

# =============================================================================
# DXC (DirectX Shader Compiler) Configuration
# =============================================================================
# Download from: https://github.com/microsoft/DirectXShaderCompiler/releases
# Or use the one bundled with VulkanSDK
# Example: third_party/DXC-1.8.2505.1/lib/x64
DXC_LIB_PATH=third_party/dxc_2025_07_14/lib/x64

# DXC include path (optional)
DXC_INCLUDE_PATH=third_party/dxc_2025_07_14/include

# Node.js for Porffor compile steps (optional; auto-detects ../.tools/node-*)
# NODE_EXE=../.tools/node-v22.16.0-win-x64/node.exe
