# Dong Build Configuration
# Copy this file to build.env and modify paths for your system
# Lines starting with # are comments

# =============================================================================
# VulkanSDK Configuration
# =============================================================================
# Path to VulkanSDK installation directory
# macOS example: /Users/username/VulkanSDK/1.4.328.1/macOS
# Windows example: C:/VulkanSDK/1.4.328.1
VULKAN_SDK_PATH=

# =============================================================================
# DXC (DirectX Shader Compiler) Configuration
# =============================================================================
# Path to DXC library directory
# macOS example: third_party/DXC-1.8.2505.1/lib/macosx
# Windows example: third_party/DXC-1.8.2505.1/lib/windows
DXC_LIB_PATH=

# Path to DXC include directory (optional, defaults to third_party/DXC-1.8.2505.1/include)
DXC_INCLUDE_PATH=third_party/DXC-1.8.2505.1/include
