# Dong Build Configuration - iOS
# Copy this file to build.env and adjust paths for your system
#
# iOS cross-compilation requires:
# 1. macOS with Xcode installed
# 2. Target architecture specified in zig build command
#
# Example build commands:
#   zig build -Dtarget=aarch64-ios                   # iOS ARM64 (devices)
#   zig build -Dtarget=x86_64-ios                    # iOS Simulator (Intel Mac)
#   zig build -Dtarget=aarch64-ios-simulator         # iOS Simulator (Apple Silicon)
#
# The build will automatically enter "libs-only" mode for mobile targets,
# building only static libraries for integration into native iOS apps.

# iOS SDK path (uses Xcode default if not specified)
# IOS_SDK_PATH=/Applications/Xcode.app/Contents/Developer/Platforms/iPhoneOS.platform/Developer/SDKs/iPhoneOS.sdk

# iOS deployment target version (default: 12.0)
# Set via: zig build -Dios-target=12.0
# Recommended minimum: 12.0 (covers ~99% of devices as of 2024)

# Note: DXC is NOT required for iOS builds
# Shaders should be pre-compiled to Metal shaders at build time

# =============================================================================
# Integration Guide for iOS Projects
# =============================================================================
#
# After building with zig build -Dtarget=aarch64-ios:
#
# 1. Static libraries will be in: zig-out/lib/
#    - libquickjs.a
#    - liblexbor_static.a
#    - libyogacore.a
#    - libfreetype.a
#    - libharfbuzz.a
#    - libmsdfgen.a
#
# 2. Create a fat/universal library (optional, for supporting multiple archs):
#    lipo -create \
#      zig-out-arm64/lib/libquickjs.a \
#      zig-out-x64-sim/lib/libquickjs.a \
#      -output lib/libquickjs.a
#
# 3. Add libraries to your Xcode project:
#    - Drag libraries into your project
#    - Add to "Link Binary With Libraries" in Build Phases
#
# 4. Header files are in: zig-out/include/
#    Add to "Header Search Paths" in Build Settings
#
# 5. Add required frameworks:
#    - Metal.framework
#    - QuartzCore.framework
#    - Foundation.framework
#
# =============================================================================
# Creating XCFramework for Distribution
# =============================================================================
#
# For easier integration, create an XCFramework:
#
# 1. Build for all architectures:
#    zig build -Dtarget=aarch64-ios -p zig-out-ios-device
#    zig build -Dtarget=aarch64-ios-simulator -p zig-out-ios-sim
#
# 2. Create XCFramework:
#    xcodebuild -create-xcframework \
#      -library zig-out-ios-device/lib/libdong.a \
#      -headers zig-out-ios-device/include \
#      -library zig-out-ios-sim/lib/libdong.a \
#      -headers zig-out-ios-sim/include \
#      -output Dong.xcframework
#
# =============================================================================
